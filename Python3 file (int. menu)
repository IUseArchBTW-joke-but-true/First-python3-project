


# Interactive menu (cool af)

print("\nHello, I'm Finn, what would you like to eat today?\n")
print('       (Type "help" for a list of commands)')

# Diccionario de precios (nombre : precio)
prices = {
    "black coffee": 1.0,
    "cookie": 1.5,
    "french toast": 2.0,
    "apple": 0.75,
    "pancake": 3.0  # hidden menu
}

# listas de items
menu_items = ["black coffee", "cookie", "french toast", "apple"]
hidden_menu = ["pancake"]

# juntar todo (menu normal + oculto)
all_items = menu_items + hidden_menu

# comandos posibles
commands = ["exit", "buy", "menu", "help"]

# FUNCION menu (esto se ejecuta SOLO cuando la llamas)
def show_menu():
    print()
    for item in menu_items:   # para cada item en el menu visible escribe :  el item + el precio
        print(f"{item} {prices[item]} $")

# FUNCION help
def show_help():
    print("\nCommands:\nhelp\nbuy\nmenu\nexit")

# FUNCION buy (solo para comprar)
def buy():
    print("\nWhat would you like to buy today? (type 'exit' to leave)")

    while True:
        order = input("> ").strip().lower()

        if order == "exit":
            print("Leaving buy menu...")
            break

        if order not in all_items:
            print('Unknown item. Type "menu" to see options.')
            continue

        quantity = input("How many? > ")
        if not quantity.isdigit():
            print("Please enter a valid number.")
            continue

        quantity = int(quantity)
        total = prices[order] * quantity

        print(rf"Okay, your {quantity} {order}(s) will be ready soon!")
        print(f"Total: {total}$")

# Bucle principal
while True:
    raw = input("\n> ").strip().lower()
    words = raw.split()

    if not words:
        continue

    choice = words[0]
    option = words[1] if len(words) > 1 else None

    if choice == "menu":
        if option == "--help":
            print("Shows the menu")
        else:
            show_menu()

    elif choice == "help":
        show_help()

    elif choice == "buy":
        if option == "--help":
            print("Use this command to buy things")
        else:
            buy()

    elif choice == "exit":
        print("\nGoodbye!")
        break

    else:
        print('Unknown command. Type "help" if you are lost.')
