

# Interactive menu (cool af)

print("\nHello, I'm Finn, what would you like to eat today?\n")
print('       (Type "help" for a list of commands)')

# Diccionario de precios (nombre : precio)
prices = {
    "black coffee": 1.0,
    "cookie": 1.5,
    "french toast": 2.0,
    "apple": 0.75,
    "pancake": 3.0  # hidden menu
}

# listas de items
menu_items = ["black coffee", "cookie", "french toast", "apple"]
hidden_menu = ["pancake"]

# juntar todo (menu normal + oculto)
all_items = menu_items + hidden_menu

# comandos posibles
commands = ["exit", "buy", "menu", "help"]


# FUNCION menu (esto se ejecuta SOLO cuando la llamas)
def show_menu():
    print()

    # recorre cada item del menu normal
    for item in menu_items:
        # imprime nombre + precio
        print(f"{item} {prices[item]} $")


# FUNCION help
def show_help():
    print("\nCommands:\nhelp\nbuy\nmenu\nexit")


# FUNCION buy (todo lo de comprar está aquí dentro)
def buy():
    print("\nWhat would you like to buy today?")

    # bucle interno SOLO para comprar
    while True:
        order = input("> ").strip().lower()   # lo que escribe el usuario

        # salir del modo compra
        if order == "exit":
            print("Leaving buy menu...")
            break

        # si no es un item válido
        if order not in all_items:
            print('Unknown item. Type "menu" to see options.')
            continue   # vuelve arriba del bucle

        # preguntar cantidad
        quantity = input("How many? > ")

        # comprobar que es un número (evita errores)
        if not quantity.isdigit():
            print("Please enter a valid number.")
            continue

        quantity = int(quantity)   # convertir a numero

        # calcular total
        total = prices[order] * quantity

        # mensaje final
        print(f"Okay, your {quantity} {order}(s) will be ready soon!")
        print(f"Total: {total}$")


# bucle principal
while True:
    choice = input("\n> ").strip().lower()

    if choice == "menu":
        show_menu()   # llama a la funcion menu

    elif choice == "help":
        show_help()   # llama a help

    elif choice == "buy":
        buy()   # entra en el modo compra

    elif choice == "exit":
        print("\nGoodbye!")
        break   # rompe el bucle y termina el programa

    else:
        # si escribe cualquier cosa rara
        print('Unknown command. Type "help" if you are lost.')
